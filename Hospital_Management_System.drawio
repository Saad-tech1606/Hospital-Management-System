        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nclass User {\n  - name: String\n  - email: String\n  - age: Integer\n  - address: String\n  - phoneNumber: String\n  - gender: String\n  + registerUser(details: Map)\n}\n\nclass OPDRegistration {\n  - name: String\n  - email: String\n  - age: Integer\n  - address: String\n  - phoneNumber: String\n  - gender: String\n  - date: Date\n  + opdRegistration(details: Map)\n}\n\nclass BedBooking {\n  - name: String\n  - email: String\n  - age: Integer\n  - address: String\n  - phoneNumber: String\n  - gender: String\n  - date: Date\n  - department: String\n  + BedBooking(details: Map)\n}\n\nclass BloodBooking {\n  - name: String\n  - email: String\n  - age: Integer\n  - address: String\n  - phoneNumber: String\n  - gender: String\n  - requiredUnits: Integer\n  - cause: String\n  + BloodBooking(details: Map)\n}\n\nclass Admin {\n  - email_ID: String\n  - password: String\n  + loginAdmin(username: String, password: String)\n  + viewAllBookings()\n  + addBooking(type: String, details: Map)\n  + updateBooking(type: String, name: String, updatedDetails: Map)\n  + deleteBooking(type: String, name: String)\n}\n\nUser \&quot;1\&quot; --&gt; \&quot;many\&quot; OPDRegistration\nUser \&quot;1\&quot; --&gt; \&quot;many\&quot; BedBooking\nUser \&quot;1\&quot; --&gt; \&quot;many\&quot; BloodBooking\nAdmin --&gt; OPDRegistration : manages\nAdmin --&gt; BedBooking : manages\nAdmin --&gt; BloodBooking : manages\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="WNxSvEQ2SxHRYIFGiDkD-4">
